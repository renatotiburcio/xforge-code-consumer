#!/bin/sh
# XForge pre-commit hook: runs doctor.ps1
# Install: git config core.hooksPath .githooks

echo "XForge pre-commit: running doctor..."
powershell -NoProfile -ExecutionPolicy Bypass -File .kilo/automation/scripts/doctor.ps1
if [ $? -ne 0 ]; then
    echo "ERROR: doctor.ps1 found errors. Fix before committing."
    exit 1
fi
echo "doctor.ps1 passed. Commit allowed."
exit 0
