    "modes":  {
                  "template":  {
                                   "git":  "Mantem remote origin para push",
                                   "description":  "Template Maintenance Mode — para evoluir o template XForge",
                                   "usage":  "cd XForge-Development-New \u0026\u0026 git pull \u0026\u0026 git push"
                               },
                  "consumer":  {
                                   "git":  "init-project.ps1 remove .git e cria novo repo",
                                   "description":  "Consumer Mode — para criar projetos baseados no template",
                                   "usage":  ".xforge/scripts/init-project.ps1 -TargetDir ../meu-projeto -Stack dotnet"
                               }
              },
    "initProject":  {
                        "script":  ".xforge/scripts/init-project.ps1",
                        "description":  "Cria projeto consumidor completo, separando do template (DR-0211)",
                        "flags":  {
                                      "WhatIf":  "Mostra o que seria feito sem alterar nada",
                                      "SkipPurify":  "Nao roda purify.ps1",
                                      "Force":  "Sobrescreve target dir se existir",
                                      "Remote":  "URL do remote do projeto (opcional)",
                                      "SkipGit":  "Nao faz operacoes git"
                                  },
                        "steps":  [
                                      "Validar",
                                      "Backup",
                                      "Copiar user-facing",
                                      "Copiar manifesto",
                                      "Remover template-only",
                                      "Detectar stack",
                                      "Git init + commit",
                                      "Atualizar .gitignore"
                                  ]
                    }
