# XForge for Kilo Code - .vscodeignore
# https://code.visualstudio.com/api/working-with-extensions/publishing-extension#vscodeignore

# Test infrastructure
test/
tests/
*.test.js
*.spec.js
__tests__/

# Build artifacts
*.vsix
*.vsix-manifest
build/
dist/
out/
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Node / npm
node_modules/
.npm/
.eslintcache
.npmrc

# Python (from engine tests in same dir)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
env/

# Hidden test artifacts
.tmp_*
*.tmp
