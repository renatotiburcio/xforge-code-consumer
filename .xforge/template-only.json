                                              "rust":  "Rust (Actix, Axum, Rocket, sqlx)",
                                              "java":  "Java/Kotlin (Spring Boot, Quarkus, Micronaut)",
                                              "fiscal":  "Dominio fiscal brasileiro (NFe, NFC-e, NFS-e, SPED, ICMS, PIS/COFINS)",
                                              "contabil":  "Dominio contabil (plano de contas, ECD, ECF, DRE)",
                                              "trabalhista":  "Dominio trabalhista (CLT, eSocial, folha, FGTS, INSS)",
